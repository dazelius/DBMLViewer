# Claude API
CLAUDE_API_KEY=your-claude-api-key-here

# GitLab (repo1 - default)
GITLAB_REPO_URL=http://your-gitlab-host/group/repo-data.git
GITLAB_TOKEN=your-gitlab-token-here

# GitLab (repo2 - aegis branch)
GITLAB_REPO2_URL=http://your-gitlab-host/group/repo.git
GITLAB_REPO2_TOKEN=your-gitlab-token-here

# Jira / Confluence
JIRA_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_DEFAULT_PROJECT=YOUR_PROJECT
CONFLUENCE_USER_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your-confluence-api-token-here

# Web Search (Brave Search API)
WEB_SEARCH_API_KEY=

# TableMaster server
DATAMASTER_PORT=5173
TABLEMASTER_HOST=localhost

# Slack Bot
SLACK_BOT_TOKEN=your-slack-bot-token-here
SLACK_APP_TOKEN=your-slack-app-token-here
